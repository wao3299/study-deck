---
import Base from "../layouts/Base.astro";
import AuthBox from "../components/AuthBox.astro";
const base = import.meta.env.BASE_URL;
const decks = [
  { href: `${base}saa/`, code: "SAA", name: "Solutions Architect Associate", note: "SAA-C03 · 297問" },
  { href: `${base}dva/`, code: "DVA", name: "Developer Associate", note: "DVA-C02 · 20問" },
  { href: `${base}dea/`, code: "DEA", name: "Data Engineer Associate", note: "DEA-C01 · 20問" },
  { href: `${base}owasp/`, code: "OWASP", name: "OWASP Top 10", note: "Web Security 2025 · 20問" },
  { href: `${base}menkyo/`, code: "免許", name: "仮免学科試験", note: "第一段階 · 100問" },
];
---
<Base title="腕試しクイズ">
  <div class="wrap">
    <header>
      <AuthBox />
      <p class="eyebrow">Quiz Decks</p>
      <h1>腕試しクイズ</h1>
      <p class="sub">挑戦するデックを選ぶ。</p>
    </header>
    <section class="card">
      <div class="home-modes">
        {decks.map((d) => (
          <a class="mode-btn" href={d.href}>
            <span class="mb-ico">{d.code}</span>
            <span class="mb-tt"><span class="mb-name">{d.name}</span><span class="mb-desc">{d.note}</span></span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>

<script>
  import { initFirebaseAuth, bindAuthUi } from "../scripts/auth-ui.js";
  /* トップページはログインのみ。統計同期は各 deck ページで行われる */
  initFirebaseAuth().then(h => { if (h) bindAuthUi(h.auth, h.authMod); });
</script>
